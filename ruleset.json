{
  "id": 17646132,
  "name": "Sign + Linear",
  "target": "branch",
  "source_type": "Repository",
  "source": "h8d13/ACR",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "refs/heads/master"
      ]
